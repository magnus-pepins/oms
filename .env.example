# OMS slice 1 environment template.
# Copy to .env for local dev. Production values are managed by deploy tooling.

# --- HTTP ingress ---
OMS_HTTP_PORT=8088
OMS_INTERNAL_API_KEY=replace-me-internal-key

# --- OpenTelemetry (optional; separate Prometheus scrape for FIX ingress→NOS histogram) ---
# When true, exposes OTel metrics on OMS_OTEL_PROMETHEUS_PORT (default 9464). Micrometer /actuator/prometheus stays on.
# OMS_OTEL_METRICS_ENABLED=false
# OMS_OTEL_PROMETHEUS_PORT=9464
# OMS_OTEL_INGRESS_TO_NOS_SAMPLE_TTL_MS=1800000
# OMS_OTEL_INGRESS_TO_NOS_EVICT_INTERVAL_MS=60000

# --- Postgres (system of record for orders, FIX sessions, control_outbox) ---
OMS_PG_URL=jdbc:postgresql://localhost:5432/oms
OMS_PG_USER=oms
OMS_PG_PASSWORD=oms
OMS_PG_POOL_MAX_SIZE=20
OMS_PG_POOL_MIN_IDLE=5
OMS_PG_CONNECTION_TIMEOUT_MS=2000

# --- Chronicle Queue (engineering replay only — NOT regulatory SoR) ---
OMS_CHRONICLE_ENABLED=true
OMS_CHRONICLE_QUEUE_DIR=./queues/control
OMS_CHRONICLE_ROLL_CYCLE=DAILY
# scheduled (default) | dedicated — see docs/chronicle-tail-driver.md
OMS_CHRONICLE_TAIL_DRIVER=scheduled
OMS_CHRONICLE_TAIL_POLL_INTERVAL_MS=50
OMS_CHRONICLE_TAIL_BATCH_MAX_MESSAGES=200
OMS_CHRONICLE_TAIL_DEDICATED_IDLE_PARK_NANOS=100000

# --- Control plane / outbox (named limit keys per config-limits playbook) ---
# Interim 5 min default — see system-documentation/plans/oms-phase0-interim-decisions.md
OMS_CONTROL_MAX_JOB_AGE_MS=300000
OMS_OUTBOX_RECONCILER_AGE_MS=2000
OMS_OUTBOX_RECONCILER_BATCH_SIZE=100
OMS_OUTBOX_RECONCILER_INTERVAL_MS=500
OMS_TAILER_BATCH_SIZE=100

# --- Slice 2 risk (0 = disabled for numeric caps; allowlist off by default) ---
OMS_RISK_INSTRUMENT_ALLOWLIST_ENABLED=false
OMS_RISK_ALLOWED_INSTRUMENT_SYMBOLS=
# When true, symbol must be in OMS_RISK_TRADABLE_INSTRUMENT_SYMBOLS (or Marketdata HTTP cache when enabled below) or control rejects RISK_INSTRUMENT_NOT_ALLOWED.
OMS_RISK_INSTRUMENT_TRADABILITY_CHECK_ENABLED=false
OMS_RISK_INSTRUMENT_TRADABILITY_FROM_MARKETDATA_ENABLED=false
OMS_RISK_TRADABLE_INSTRUMENT_SYMBOLS=
# When true, symbols in OMS_RISK_HALTED_INSTRUMENT_SYMBOLS reject with RISK_SYMBOL_HALT (before allowlist / tradability).
OMS_RISK_INSTRUMENT_SYMBOL_HALT_CHECK_ENABLED=false
OMS_RISK_HALTED_INSTRUMENT_SYMBOLS=
OMS_RISK_FAT_FINGER_MAX_LIMIT_PRICE=0
OMS_RISK_FAT_FINGER_MAX_ORDER_QUANTITY=0
OMS_RISK_MAX_ORDER_NOTIONAL=0
OMS_RISK_FIX_ROUTE_SEND_ENABLED_CHECK_ENABLED=false
OMS_RISK_MAX_AGGREGATE_POSITION_QUANTITY_CHECK_ENABLED=false
OMS_RISK_MAX_AGGREGATE_POSITION_QUANTITY=0

# --- Optional Marketdata HTTP client (instruments cache + NBBO for market_context; off by default) ---
OMS_MARKETDATA_HTTP_ENABLED=false
OMS_MARKETDATA_HTTP_BASE_URL=http://localhost:6001
OMS_MARKETDATA_HTTP_API_KEY=
OMS_MARKETDATA_HTTP_CONNECT_TIMEOUT_MS=2000
OMS_MARKETDATA_HTTP_READ_TIMEOUT_MS=5000
OMS_MARKETDATA_HTTP_INSTRUMENTS_PATH=/internal/v0/instruments
OMS_MARKETDATA_HTTP_NBBO_PATH=/internal/v0/nbbo
OMS_MARKETDATA_HTTP_INSTRUMENTS_REFRESH_INTERVAL_MS=60000
OMS_MARKETDATA_HTTP_NBBO_IN_MARKET_CONTEXT_ENABLED=false

# --- Slice 3 routing / return path (noop default; simulated = in-process test broker) ---
OMS_ROUTING_BACKEND=noop
# simulated = synthetic ER path; fix = outbound FIX queue (see oms/docs/fix-out.md)
OMS_MARKET_CONTEXT_STUB_JSON={"stub":true}
# When true, trade apply may merge nbboClassReference (HTTP NBBO if marketdata flags on, else stub bid/ask).
OMS_ROUTING_NBBO_REFERENCE_IN_MARKET_CONTEXT_ENABLED=false
OMS_ROUTING_NBBO_STUB_BID_PRICE=0
OMS_ROUTING_NBBO_STUB_ASK_PRICE=0
OMS_SIMULATED_VENUE_ID=SIM
OMS_SIMULATED_QUEUE_CAPACITY=10000
OMS_SIMULATED_POLL_INTERVAL_MS=50
OMS_SIMULATED_SCHEDULER_ENABLED=true

# --- Slice 6 settlement spine (positions / custody; must exist in custody_accounts — Flyway V11 seed) ---
OMS_SETTLEMENT_DEFAULT_CUSTODY_ACCOUNT_ID=a0000001-0000-4000-8000-000000000001
# When true, scheduled job drains broker_settlement_confirm (default false; IT uses HTTP or direct processor).
OMS_SETTLEMENT_BROKER_CONFIRM_RECONCILER_ENABLED=false
OMS_SETTLEMENT_BROKER_CONFIRM_RECONCILER_INTERVAL_MS=10000
OMS_SETTLEMENT_BROKER_CONFIRM_RECONCILER_BATCH_SIZE=50
OMS_SETTLEMENT_BROKER_CONFIRM_HTTP_MAX_EXECUTION_IDS=100
OMS_SETTLEMENT_FILE_IMPORT_MAX_BYTES=10000000
OMS_SETTLEMENT_FILE_IMPORT_MAX_ROWS=10000
OMS_SETTLEMENT_FILE_IMPORT_REGISTER_SLICE_SIZE=50
OMS_SETTLEMENT_FILE_IMPORT_ERROR_SUMMARY_MAX_CHARS=2000
OMS_SETTLEMENT_FILE_IMPORT_LIST_MAX_LIMIT=200
OMS_SETTLEMENT_FILE_IMPORT_LIST_DEFAULT_LIMIT=50
# Optional: drop-folder ingest (same JSON as file-import; use rclone/S3→disk for cloud paths)
# OMS_SETTLEMENT_FILE_IMPORT_DROP_FOLDER_ENABLED=true
# OMS_SETTLEMENT_FILE_IMPORT_DROP_FOLDER_PATH=/var/lib/oms/broker-incoming
# OMS_SETTLEMENT_FILE_IMPORT_DROP_FOLDER_POLL_INTERVAL_MS=30000
# OMS_SETTLEMENT_FILE_IMPORT_DROP_FOLDER_MAX_FILES_PER_POLL=20
OMS_SETTLEMENT_FREE_RIDING_ATTRIBUTION_ENABLED=false
OMS_SETTLEMENT_FREE_RIDING_ATTRIBUTION_MAX_FUNDING_EXECUTIONS=8

OMS_CORPORATE_ACTION_PROCESSOR_ENABLED=false
OMS_CORPORATE_ACTION_PROCESSOR_INTERVAL_MS=60000
OMS_CORPORATE_ACTION_PROCESSOR_BATCH_SIZE=50
OMS_CORPORATE_ACTION_INGEST_INSTRUMENT_SYMBOL_MAX_LENGTH=64
OMS_CORPORATE_ACTION_INGEST_ACTION_TYPE_MAX_LENGTH=64
OMS_CORPORATE_ACTION_INGEST_PAYLOAD_JSON_MAX_CHARS=16000

# --- Slice 4 FIX (when OMS_ROUTING_BACKEND=fix; initiator only if OMS_FIX_AUTO_START=true) ---
OMS_FIX_AUTO_START=false
OMS_FIX_OUTBOUND_QUEUE_CAPACITY=10000
OMS_FIX_FILE_STORE_PATH=./queues/fix
OMS_FIX_SOCKET_CONNECT_HOST=127.0.0.1
OMS_FIX_SOCKET_CONNECT_PORT=9876
OMS_FIX_SENDER_COMP_ID=OMS_INIT
OMS_FIX_TARGET_COMP_ID=BROKER_ACCEPT
OMS_FIX_HEART_BT_INT=30
OMS_FIX_OUTBOUND_POLL_INTERVAL_MS=100
OMS_FIX_MAX_OUTBOUND_JOB_AGE_MS=0
OMS_FIX_VENUE_ID_FOR_EXECUTIONS=FIX
OMS_FIX_USE_DATA_DICTIONARY=false
# JSON object mapping OMS instrument_symbol → broker FIX Symbol (e.g. {"AAPL":"AAPL.NMS"}); leave empty for identity.
OMS_FIX_SYMBOL_MAP_JSON=
# Logical route for fix_route_state.send_enabled (default single row).
OMS_FIX_ROUTE_KEY=default
# NOS token bucket: <=0 disables; burst used when rate > 0.
OMS_FIX_OUTBOUND_TOKENS_PER_SECOND=0
OMS_FIX_OUTBOUND_TOKEN_BURST=100
# file (default) or jdbc — jdbc uses oms_fix_sessions / oms_fix_messages (Flyway V9) via app DataSource.
OMS_FIX_SESSION_STORE_TYPE=file
# Start-of-day: set send_enabled=true on all fix_route_state rows (disabled by default).
OMS_FIX_ROUTE_STATE_SOD_ENABLED=false
OMS_FIX_ROUTE_STATE_SOD_CRON=0 0 6 * * *
# always | weekdays | region_calendar — gate FixRouteStateSodScheduler (default always = legacy behaviour).
OMS_FIX_ROUTE_STATE_SOD_POLICY_MODE=always
OMS_FIX_ROUTE_STATE_SOD_POLICY_ZONE_ID=UTC
# When mode=region_calendar: {"activeRegionId":"default","regions":{"default":{"allowedWeekdays":[1,2,3,4,5],"blockedDates":[],"forcedDates":[]}}}
OMS_FIX_ROUTE_STATE_SOD_POLICY_CALENDAR_JSON={}
# TLS to broker UAT/prod (QuickFIX SocketUseSSL and related settings).
OMS_FIX_SOCKET_USE_SSL=false
OMS_FIX_SOCKET_KEY_STORE=
OMS_FIX_SOCKET_KEY_STORE_PASSWORD=
OMS_FIX_SOCKET_TRUST_STORE=
OMS_FIX_SOCKET_TRUST_STORE_PASSWORD=
OMS_FIX_ENABLED_SSL_PROTOCOLS=
# Dedicated JDBC pool for QuickFIX JdbcStore (optional; master plan 6.4 isolation from application Hikari pool).
OMS_FIX_SESSION_JDBC_DATASOURCE_ENABLED=false
OMS_FIX_SESSION_JDBC_URL=
OMS_FIX_SESSION_JDBC_USER=
OMS_FIX_SESSION_JDBC_PASSWORD=
OMS_FIX_SESSION_JDBC_POOL_MAX_SIZE=5
OMS_FIX_SESSION_JDBC_POOL_MIN_IDLE=1
OMS_FIX_SESSION_JDBC_CONNECTION_TIMEOUT_MS=2000

# --- Sharding (slice 1 single-shard) ---
OMS_SHARD_ID=0
OMS_SHARD_COUNT=1

# --- NATS (optional fanout for desk UI / drop copy / ops; off by default in slice 1) ---
OMS_NATS_ENABLED=false
OMS_NATS_URL=nats://localhost:4222
OMS_NATS_SUBJECT_PREFIX=oms.events
OMS_NATS_STREAM_NAME=OMS_EVENTS
OMS_NATS_CONNECTION_TIMEOUT_MS=5000

# --- Ledger (optional BUY buying-power gate before WORKING; off by default) ---
OMS_LEDGER_ENABLED=false
OMS_LEDGER_BASE_URL=http://localhost:5001
OMS_LEDGER_API_KEY=
OMS_LEDGER_CONNECT_TIMEOUT_MS=2000
OMS_LEDGER_READ_TIMEOUT_MS=5000
# When true, OMS POSTs a Ledger sync inflight hold on BUY accept (requires destination balance id below).
OMS_LEDGER_INFLIGHT_RESERVATION_ENABLED=false
# Ledger balance_id that receives the hold leg (bank suspense / OMS hold account). Required when inflight reservation is enabled.
OMS_LEDGER_INFLIGHT_HOLD_DESTINATION_BALANCE_ID=
OMS_LEDGER_INFLIGHT_RESERVATION_CURRENCY=EUR
OMS_LEDGER_INFLIGHT_RESERVATION_PRECISION=100
# When true, OMS writes ledger_settlement_outbox when a TRADE reaches settled (same DB txn as settlement CAS).
OMS_LEDGER_SETTLEMENT_OUTBOX_ENABLED=false
# When true (and OMS_LEDGER_ENABLED), LedgerSettlementOutboxReconciler POSTs unposted rows and sets posted_at.
OMS_LEDGER_SETTLEMENT_OUTBOX_RECONCILER_ENABLED=false
OMS_LEDGER_SETTLEMENT_OUTBOX_RECONCILER_AGE_MS=2000
OMS_LEDGER_SETTLEMENT_OUTBOX_RECONCILER_BATCH_SIZE=50
OMS_LEDGER_SETTLEMENT_OUTBOX_RECONCILER_INTERVAL_MS=500
# Path on Ledger base URL for settlement outbox POST (default matches application.yaml).
OMS_LEDGER_SETTLEMENT_POSTING_HTTP_PATH=/internal/v0/settlement-outbox

# --- Domain fanout outbox (Postgres → NATS / desk / drop copy) ---
OMS_DOMAIN_EVENTS_RECONCILER_AGE_MS=2000
OMS_DOMAIN_EVENTS_RECONCILER_BATCH_SIZE=100
OMS_DOMAIN_EVENTS_RECONCILER_INTERVAL_MS=500

# --- PII policy ---
# When true, raw account_id MAY appear in audit-grade trace logs (only behind explicit flag).
# Default false: only hashed account_id appears anywhere.
OMS_PII_AUDIT_TRACE_ENABLED=false
OMS_PII_HASH_SECRET=replace-me-hash-secret
